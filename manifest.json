{
  "manifest_version": 3,
  "name": "Webpage to Markdown",
  "version": "1.2",
  "description": "Convert any webpage to clean Markdown in one click. Copy or download as .md for Obsidian, Notion, GitHub, or AI prompts.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
} 